# Telegram Bot Token (полученный у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Список Telegram ID пользователей, которым разрешен доступ к управлению ПК (через запятую)
# Пример: ALLOWED_USERS=1298560755,987654321
# Если вы не знаете свой ID, запустите бота, и ваш ID отобразится в консоли при попытке написать ему
ALLOWED_USERS=your_telegram_id_here
